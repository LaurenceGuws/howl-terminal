{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "zig build",
      "type": "shell",
      "command": "zig",
      "args": ["build"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "zig build test",
      "type": "shell",
      "command": "zig",
      "args": ["build", "test"],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": ["$rustc"]
    }
  ]
}
